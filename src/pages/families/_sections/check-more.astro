---
import { COLORS } from '../../../constants';
import Button from '../../../components/ui/Button.astro';

interface Props {
  content: { text: string; boldText?: string; link: string };
  dark?: boolean;
}

const { content = { text: '', boldText: '', link: '' }, dark = false } = Astro.props;
const isExternal = content.link?.startsWith('http');
---

<section
  class="pt-8 pb-20 relative overflow-hidden font-sans"
  style={{ backgroundColor: dark ? COLORS.blue.navy : COLORS.white }}
>
  <div class="container mx-auto px-4 lg:px-8 relative z-10">
    <div class="flex justify-center max-w-3xl mx-auto">
      <Button
        variant="outline"
        href={content.link}
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener noreferrer' : undefined}
        className={`bg-white no-underline hover:no-underline shadow-md ${dark ? 'hover:bg-blue-50' : 'hover:bg-gray-50'}`}
      >
        <span class="inline-flex items-baseline flex-wrap justify-center">
          <span>{content.text.trimEnd()}</span>
          {content.boldText && <strong class="ml-1">{content.boldText}</strong>}
        </span>
      </Button>
    </div>
  </div>
</section>
