---
import { COLORS } from '../../../constants';

interface Props {
  bodyHtml?: string;
}

const { bodyHtml = '' } = Astro.props;
---

<section
  class="credibility-section font-sans py-16 lg:py-20"
  style={{ backgroundColor: COLORS.white }}
>
  <div class="container mx-auto max-w-6xl px-6 lg:px-12">
    <div class="credibility-inner">
      {bodyHtml && <div class="credibility-body" set:html={bodyHtml} />}
    </div>
  </div>
</section>

<style define:vars={{ navy: COLORS.blue.navy, royal: COLORS.blue.royal }}>
  /* Match readable width / rhythm with other support narrative blocks (e.g. other ways intro). */
  .credibility-inner {
    max-width: 48rem;
    margin-inline: auto;
    text-align: center;
  }

  .credibility-body {
    font-size: 1rem;
    line-height: 1.65;
    font-weight: 400;
    color: var(--navy);
    margin: 0;
  }

  .credibility-body :global(p) {
    margin: 0 0 1rem;
  }

  .credibility-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .credibility-body :global(strong) {
    font-weight: 600;
  }

  .credibility-body :global(a) {
    color: var(--royal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .credibility-body :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  @media (min-width: 768px) {
    .credibility-body {
      font-size: 1.0625rem;
      line-height: 1.65;
    }
  }
</style>
