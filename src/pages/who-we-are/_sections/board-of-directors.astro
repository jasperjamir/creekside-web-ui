---
import { COLORS } from '../../../constants';

interface Member {
  name?: string;
  role?: string | null;
  bio?: string;
  photo?: {
    asset?: { url?: string };
    alt?: string;
  };
}

interface Props {
  title?: string;
  members?: readonly Member[];
}

const { title = '', members = [] } = Astro.props;
---

<section
  id="board-of-directors"
  class="py-16 lg:py-20"
  style={{ backgroundColor: COLORS?.blue?.navy ?? '#052049' }}
>
  <div class="container mx-auto px-4 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold mb-10">
      <span
        class="px-2 inline-block"
        style={{ backgroundColor: COLORS.green, color: COLORS.blue.navy }}
      >
        {title}
      </span>
    </h2>
    <div class="mt-10 space-y-12 max-w-4xl">
      {members.map((member) => (
        <div class="border-b border-blue-200/40 pb-10 last:border-b-0 last:pb-0">
          <div class="flex flex-col sm:flex-row gap-5 sm:gap-6 items-start">
            {member.photo?.asset?.url ? (
              <img
                src={member.photo.asset.url}
                alt={member.photo.alt ?? member.name ?? 'Board member photo'}
                class="w-44 sm:w-48 aspect-[4/5] rounded-2xl object-cover object-center shrink-0"
                loading="lazy"
              />
            ) : (
              <div
                class="w-44 sm:w-48 aspect-[4/5] rounded-2xl flex items-center justify-center text-3xl font-bold shrink-0"
                style={{ backgroundColor: COLORS?.blue?.light ?? '#dbeafe', color: COLORS?.blue?.navy ?? '#052049' }}
              >
                {(member.name ?? '')
                  .split(' ')
                  .filter(Boolean)
                  .slice(0, 2)
                  .map((n) => n[0]?.toUpperCase())
                  .join('')}
              </div>
            )}
            <div>
              <h3 class="text-xl font-bold text-white">
                {member.name ?? ''}
              </h3>
              {member.role && (
                <p class="text-base font-medium text-blue-100 mt-1">{member.role}</p>
              )}
              {member.bio && <p class="text-blue-50 leading-relaxed mt-3">{member.bio}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
