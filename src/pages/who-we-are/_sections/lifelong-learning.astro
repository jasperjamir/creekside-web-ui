---
import ImageTextSection from '../../../components/sections/ImageTextSection.astro';
import Button from '../../../components/ui/Button.astro';

interface Props {
  headline: string;
  subheading: string;
  body: string;
  image?: { asset?: { url: string }; alt?: string };
}

const { headline = '', subheading = '', body = '', image } = Astro.props;
const imageUrl = image?.asset?.url ?? '';
const imageAlt = image?.alt ?? '';
---

<ImageTextSection
  sectionId="lifelong-learning"
  title={headline}
  subheading={subheading}
  imageUrl={imageUrl}
  imageAlt={imageAlt}
  imageLeft={true}
  backgroundColor="white"
>
  <p class="text-lg leading-relaxed">
    {body}
  </p>
  <div class="flex flex-wrap gap-4 mt-6">
    <Button variant="primary" href="/who-we-are/our-story/">Our Story</Button>
    <Button variant="outline" href="/who-we-are/our-team/">Our Team</Button>
  </div>
</ImageTextSection>
