---
import { COLORS } from '../../../constants';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import Button from '../../../components/ui/Button.astro';

interface Props {
  heading: string;
  body: string;
  videoUrl?: string;
  posterUrl?: string;
  videoAlt?: string;
}

const { heading = '', body = '', videoUrl = '', posterUrl = '', videoAlt = '' } = Astro.props;
---

<section class="py-20" style={{ backgroundColor: COLORS.cream }}>
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="max-w-2xl">
        <SectionHeading>{heading}</SectionHeading>
        <p class="text-xl md:text-2xl text-gray-700 leading-relaxed font-light mt-8">
          {body}
        </p>
        <div class="h-1 w-24 mt-8 rounded-full" style={{ backgroundColor: COLORS.blue.royal }}></div>
        <div class="mt-8">
          <Button variant="primary" href="/families/admissions-process/" className="shadow-lg transform hover:-translate-y-0.5">
            Admissions
          </Button>
        </div>
      </div>
      {videoUrl && (
        <div class="flex justify-center lg:justify-end">
          <div class="w-full max-w-lg overflow-hidden rounded-2xl shadow-md aspect-[5/3]">
            <video
              src={videoUrl}
              poster={posterUrl}
              aria-label={videoAlt}
              class="w-full h-full object-cover object-center"
              autoplay
              muted
              loop
              playsinline
              controls
              preload="metadata"
            />
          </div>
        </div>
      )}
    </div>
  </div>
</section>
