---
import { COLORS } from '../../../constants';
import SectionHeading from '../../../components/ui/SectionHeading.astro';

interface Props {
  title?: string;
  text?: string;
}

const { title = '', text = '' } = Astro.props;
---

<section
  class="eo-section font-sans py-16 lg:py-20"
  style={{ backgroundColor: COLORS.white }}
>
  <div class="container mx-auto max-w-6xl px-6 lg:px-12">
    <div class="eo-inner">
      {title && (
        <div class="text-center mb-8">
          <SectionHeading className="inline-block">{title}</SectionHeading>
        </div>
      )}
      {text && <p class="eo-body">{text}</p>}
    </div>
  </div>
</section>

<style define:vars={{ navy: COLORS.blue.navy }}>
  .eo-inner {
    max-width: 48rem;
    margin-inline: auto;
    text-align: center;
  }

  .eo-body {
    font-size: 1rem;
    line-height: 1.65;
    font-weight: 400;
    color: var(--navy);
    margin: 0;
  }

  @media (min-width: 768px) {
    .eo-body {
      font-size: 1.0625rem;
      line-height: 1.65;
    }
  }

  @media (max-width: 767px) {
    .eo-body {
      font-size: 1rem;
    }
  }
</style>
