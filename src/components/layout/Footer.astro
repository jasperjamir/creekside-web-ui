---
import { LOGO_URL, COLORS, MAILING_LIST_SIGNUP_URL, QUICK_LINKS, SOCIAL_LINKS } from '../../constants';
---

<footer class="text-white pt-16 pb-8 font-sans" style={{ backgroundColor: COLORS.blue.navy }}>
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2 text-white">
          <img src={LOGO_URL} alt="Logo" class="h-10 w-auto rounded-full bg-white border border-white" />
          The Creekside School
        </h3>
        <p class="text-white mb-4 leading-relaxed text-sm">
          Creekside School is a nonpublic school serving students with moderate-to-severe autism in Santa Clara County.
        </p>
        <div class="flex flex-wrap items-center gap-3" aria-label="Social media">
          {SOCIAL_LINKS.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social-link inline-flex items-center justify-center w-10 h-10 rounded-full border border-white/25 text-blue-200 hover:text-white hover:border-white/55 hover:bg-white/10 transition-colors"
              aria-label={link.ariaLabel}
            >
              {link.id === 'facebook' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.99 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.99 22 12z"
                    clip-rule="evenodd"
                  />
                </svg>
              )}
              {link.id === 'linkedin' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  />
                </svg>
              )}
              {link.id === 'instagram' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                  />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-lg font-bold mb-4 uppercase tracking-wide" style={{ color: COLORS.green }}>Contact Us</h4>
        <ul class="space-y-4 text-white">
          <li class="flex items-start">
            <svg class="mr-3 mt-1 flex-shrink-0 text-white" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>5629 Lean Avenue,<br/>San Jose, CA 95123</span>
          </li>
          <li class="flex items-center">
            <svg class="mr-3 flex-shrink-0 text-white" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <a href="tel:408-448-2494" class="text-blue-300 hover:text-white transition-colors">408-448-2494</a>
          </li>
          <li class="flex items-center">
            <svg class="mr-3 flex-shrink-0 text-white" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <a href="mailto:info@creeksideschool.org" class="text-blue-300 hover:text-white transition-colors">info@creeksideschool.org</a>
          </li>
          <li class="flex items-center">
            <svg class="mr-3 flex-shrink-0 text-white" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
            <a
              href={MAILING_LIST_SIGNUP_URL}
              class="text-blue-300 hover:text-white transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              Sign up to receive our updates
            </a>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-bold mb-4 uppercase tracking-wide" style={{ color: COLORS.green }}>Quick Links</h4>
        <ul class="space-y-2 text-white">
          {QUICK_LINKS.map((item) => (
            <li>
              <a href={item.href} class="text-blue-300 hover:text-white hover:underline transition-all">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal/Tax -->
      <div>
        <h4 class="text-lg font-bold mb-4 uppercase tracking-wide" style={{ color: COLORS.green }}>Support</h4>
        <p class="text-sm text-white mb-4">
          Gifts are tax-deductible as allowed by law.
        </p>
      </div>
    </div>
    
    <div class="border-t border-blue-900 pt-8 text-center text-white text-sm">
      &copy; {new Date().getFullYear()} The Creekside School. All rights reserved.
    </div>
  </div>
</footer>
